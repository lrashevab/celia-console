# ══════════════════════════════════════════════════════
# Life OS — 環境變數範本
# 複製為 .env 後填入實際值，絕不 commit .env
# ══════════════════════════════════════════════════════

# ── AI 語言模型 ──────────────────────────────────────

# Google Gemini API 金鑰（LLM 主力，必填）
# 免費取得：https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Anthropic Claude API 金鑰（備用 LLM，用於 /meeting 逐字稿結構化，選填）
# 取得：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Tavily 搜尋 API 金鑰（網路搜尋 / 文化雷達功能，選填）
# 取得：https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# ── 工作帳號 Google 服務 ─────────────────────────────

# 工作用 Google Sheets 試算表 ID（從試算表網址取得）
WORK_SPREADSHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 工作用 Google 行事曆 ID（通常為工作 Gmail 信箱）
WORK_CALENDAR_ID=your_work_email@gmail.com

# ── 個人帳號 Google 服務 ─────────────────────────────

# 個人用 Google Sheets 試算表 ID（從試算表網址取得）
PERSONAL_SPREADSHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 個人用 Google 行事曆 ID（通常為個人 Gmail 信箱）
PERSONAL_CALENDAR_ID=your_personal_email@gmail.com

# ── 本地儲存 ─────────────────────────────────────────

# 日記本地儲存路徑（不同步至 Google，保護隱私）
DIARY_LOCAL_PATH=./data/personal/diary/
